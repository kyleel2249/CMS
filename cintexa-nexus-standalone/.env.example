# ── Required ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Local: install PostgreSQL, create a database, and paste the connection URL.
# Cloud options: Neon (free tier) → https://neon.tech
#                Supabase (free tier) → https://supabase.com
#                Railway → https://railway.app
DATABASE_URL=postgresql://user:password@localhost:5432/cintexa_nexus

# ── AI Features (optional but recommended) ───────────────────────────────────
# OpenRouter API key — enables Copilot, deal scoring, anomaly detection, etc.
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# ── Server ───────────────────────────────────────────────────────────────────
# Port the combined server listens on (default: 3000)
PORT=3000

# ── Session ──────────────────────────────────────────────────────────────────
# Random secret for signing session cookies — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string
